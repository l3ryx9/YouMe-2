{
  "name": "youme-V2",
  "version": "1.0.0",
  "description": "YouMe V2 — Application de messagerie privée avec IA locale",
  "main": "expo-router/entry",
  "license": "MIT",
  "private": true,
  "packageManager": "pnpm@10.26.1",
  "scripts": {
    "preinstall": "sh -c 'rm -f package-lock.json yarn.lock; case \"$npm_config_user_agent\" in pnpm/*) ;; *) echo \"Use pnpm instead\" >&2; exit 1 ;; esac'",
    "eas-build-pre-install": "npm install -g pnpm@10.26.1",
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android",
    "build:ios": "eas build --platform ios",
    "build:preview": "eas build --profile preview",
    "test": "jest --watchAll=false",
    "test:watch": "jest --watchAll",
    "test:coverage": "jest --coverage",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck:libs": "tsc --build",
    "typecheck": "tsc --noEmit && pnpm run typecheck:libs && pnpm -r --filter \"./artifacts/**\" --filter \"./scripts\" --if-present run typecheck",
    "build": "pnpm run typecheck && pnpm -r --if-present run build"
  },
  "pnpm": {
    "overrides": {
      "metro": "0.80.9",
      "metro-config": "0.80.9",
      "metro-resolver": "0.80.9",
      "metro-cache": "0.80.9",
      "metro-core": "0.80.9",
      "metro-source-map": "0.80.9",
      "metro-transform-worker": "0.80.9"
    }
  },
  "dependencies": {
    "@expo/vector-icons": "^14.0.0",
    "@hookform/resolvers": "^3.9.0",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native-community/netinfo": "11.3.1",
    "@react-native-firebase/app": "^20.4.0",
    "@react-native-firebase/messaging": "^20.4.0",
    "@supabase/supabase-js": "^2.44.4",
    "@tanstack/react-query": "^5.45.1",
    "@xenova/transformers": "^2.17.2",
    "date-fns": "^3.6.0",
    "expo": "~51.0.0",
    "expo-asset": "~10.0.10",
    "expo-av": "~14.0.5",
    "expo-build-properties": "~0.12.5",
    "expo-constants": "~16.0.2",
    "expo-crypto": "~13.0.2",
    "expo-device": "~6.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.9",
    "expo-haptics": "~13.0.1",
    "expo-image-picker": "~15.0.7",
    "expo-linear-gradient": "~13.0.2",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.1",
    "expo-notifications": "~0.28.8",
    "expo-router": "~3.5.0",
    "expo-secure-store": "~13.0.1",
    "expo-splash-screen": "~0.27.5",
    "expo-sqlite": "^14.0.3",
    "expo-status-bar": "~1.12.1",
    "expo-task-manager": "~11.8.2",
    "lodash": "^4.17.21",
    "onnxruntime-react-native": "1.14.0",
    "react": "18.2.0",
    "react-hook-form": "^7.52.1",
    "react-native": "0.74.2",
    "react-native-audio-recorder-player": "^3.6.10",
    "react-native-fast-tflite": "^1.5.0",
    "react-native-gesture-handler": "~2.16.1",
    "react-native-get-random-values": "~1.11.0",
    "react-native-image-crop-picker": "^0.40.3",
    "react-native-image-zoom-viewer": "^3.0.1",
    "react-native-live-audio-stream": "^1.0.0",
    "react-native-maps": "1.14.0",
    "react-native-mmkv": "^2.12.2",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "~3.10.1",
    "react-native-recaptcha-that-works": "^1.3.1",
    "react-native-safe-area-context": "4.10.1",
    "react-native-screens": "3.31.1",
    "react-native-svg": "15.2.0",
    "react-native-vector-icons": "^10.1.0",
    "react-native-webview": "~13.8.6",
    "tweetnacl": "^1.0.3",
    "tweetnacl-util": "^0.15.1",
    "uuid": "^10.0.0",
    "zod": "^3.23.8",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.24.0",
    "@testing-library/jest-native": "^5.4.3",
    "@types/jest": "^29.5.12",
    "@types/lodash": "^4.17.5",
    "@types/react": "~18.2.79",
    "@types/react-native": "~0.73.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.14.1",
    "@typescript-eslint/parser": "^7.14.1",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "javascript-obfuscator": "^4.1.1",
    "jest": "^29.7.0",
    "jest-expo": "^51.0.3",
    "metro": "0.80.9",
    "metro-config": "0.80.9",
    "metro-minify-terser": "0.80.9",
    "metro-resolver": "0.80.9",
    "prettier": "^3.9.5",
    "react-test-renderer": "18.2.0",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "jest-expo",
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|@xenova/transformers|uuid)"
    ],
    "setupFilesAfterEnv": [],
    "moduleFileExtensions": ["ts", "tsx", "js", "jsx"],
    "collectCoverageFrom": [
      "src/**/*.{ts,tsx}",
      "!src/**/*.d.ts",
      "!src/**/__tests__/**"
    ],
    "coverageThreshold": {
      "global": { "branches": 60, "functions": 60, "lines": 60 }
    },
    "moduleNameMapper": {
      "^react-native-mmkv$": "<rootDir>/__mocks__/react-native-mmkv.js",
      "^onnxruntime-react-native$": "<rootDir>/__mocks__/onnxruntime-react-native.js",
      "^expo-file-system$": "<rootDir>/__mocks__/expo-file-system.js",
      "^expo-secure-store$": "<rootDir>/__mocks__/expo-secure-store.js",
      "^@react-native-async-storage/async-storage$": "<rootDir>/__mocks__/async-storage.js",
      "^@xenova/transformers$": "<rootDir>/__mocks__/xenova-transformers.js",
      "^uuid$": "<rootDir>/__mocks__/uuid.js"
    }
  }
}
